# Copy this file to .env.local for local dev,
# and add the same keys in your GitHub repo secrets (or Vercel/Netlify) for deployment.
# The six Firebase values come from Firebase Console > Project Settings > General > Your apps > SDK setup.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Places API key, used for business-name/address autocomplete
# when adding a vendor. From Google Cloud Console > APIs & Services >
# Credentials. See README for setup steps (billing account required,
# but a small directory should stay within the monthly free credit).
VITE_GOOGLE_PLACES_API_KEY=
