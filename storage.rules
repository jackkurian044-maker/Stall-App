rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Vendor listing photos. Any signed-in user can upload (the app's own
    // UI only exposes this to the listing's owner or an admin, but Storage
    // rules alone can't easily verify "owns this specific vendor doc"
    // without extra complexity, so this is enforced at the app level, not
    // the rules level — acceptable for a small local directory, worth
    // revisiting if abuse ever becomes a concern).
    match /vendor-photos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
