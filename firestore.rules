rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Vendor listings: anyone can read (public search).
    // Any signed-in user can create a listing (it becomes theirs).
    // A listing can be edited/deleted by its owner, by an admin,
    // or claimed by a signed-in user who supplies the correct claimCode
    // on a currently-unclaimed (ownerId == null) listing.
    match /vendors/{vendorId} {
      allow read: if true;

      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        (isAdmin() && request.resource.data.ownerId == null)
      );

      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        isAdmin() ||
        (
          resource.data.ownerId == null &&
          request.resource.data.ownerId == request.auth.uid &&
          request.resource.data.claimCode == resource.data.claimCode
        )
      ) || (
        // Anyone — including anonymous browsers — can bump interaction
        // counters (view/call/whatsapp/directions) to power analytics and
        // social proof. This must work without sign-in, since customers
        // browsing Stall don't need an account. The affectedKeys() check
        // is what keeps this safe: it only ever touches these four
        // counter fields and nothing else on the listing.
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['viewCount', 'callCount', 'whatsappCount', 'directionsCount'])
      );

      allow delete: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid || isAdmin());

      // Reviews left by any signed-in user. One review per user per
      // vendor, enforced by using the reviewer's own UID as the doc ID —
      // submitting again just edits their existing review instead of
      // creating a second one.
      match /reviews/{uid} {
        allow read: if true;
        allow create, update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null &&
          (request.auth.uid == uid || isAdmin());
      }

      // Raw interaction events (view/call/whatsapp/directions), used to
      // compute real time-windowed counts (e.g. "recent" views) rather
      // than a misleading all-time number. Write-only for clients —
      // nobody, including the vendor themselves, reads individual event
      // rows; only admins can read them (e.g. for abuse investigation).
      // Anonymous writes are allowed for the same reason as the counter
      // update above: customers browsing shouldn't need an account.
      match /events/{eventId} {
        allow create: if request.resource.data.type in ['view', 'call', 'whatsapp', 'directions'];
        allow read: if isAdmin();
        allow update, delete: if false;
      }
    }

    // Admin membership list. Documents here are added manually via the
    // Firebase Console (doc ID = the admin's Firebase Auth UID).
    // No client can write to this collection.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Reports (dispute a listing). Anyone signed in or anonymous can file
    // one — that's deliberate, requiring an account to report something
    // wrong would just suppress reports. Nobody but admins can read or
    // resolve them; a report is never publicly visible and never affects
    // the listing on its own.
    match /reports/{reportId} {
      allow create: if request.resource.data.status == 'open';
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // Favorites: fully private to each user. A user can only read/write
    // their own favorites subcollection, never anyone else's.
    match /users/{uid} {
      match /favorites/{vendorId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Weekly digests (see digestFunctions.js). Written only by Cloud
    // Functions via the Admin SDK, which bypasses these rules entirely —
    // so "write: if false" here just blocks any *client* from forging
    // their own digest. Reading and marking-as-read stays client-side.
    match /digests/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    match /vendor_digests/{vendorId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/vendors/$(vendorId)).data.ownerId == request.auth.uid ||
        isAdmin()
      );
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/vendors/$(vendorId)).data.ownerId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // Internal bookkeeping for weeklyVendorDigest's week-over-week
    // comparison — never read by any client, only by the Cloud Function
    // itself (Admin SDK, bypasses rules).
    match /vendor_counter_snapshots/{vendorId} {
      allow read, write: if false;
    }
  }
}
