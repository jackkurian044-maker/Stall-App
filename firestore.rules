rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Vendor listings: anyone can read (public search).
    // Any signed-in user can create a listing (it becomes theirs).
    // A listing can be edited/deleted by its owner, by an admin,
    // or claimed by a signed-in user who supplies the correct claimCode
    // on a currently-unclaimed (ownerId == null) listing.
    match /vendors/{vendorId} {
      allow read: if true;

      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        (isAdmin() && request.resource.data.ownerId == null)
      );

      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        isAdmin() ||
        (
          resource.data.ownerId == null &&
          request.resource.data.ownerId == request.auth.uid &&
          request.resource.data.claimCode == resource.data.claimCode
        )
      );

      allow delete: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid || isAdmin());

      // Reviews left by any signed-in user. One review per user per
      // vendor, enforced by using the reviewer's own UID as the doc ID —
      // submitting again just edits their existing review instead of
      // creating a second one.
      match /reviews/{uid} {
        allow read: if true;
        allow create, update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null &&
          (request.auth.uid == uid || isAdmin());
      }
    }

    // Admin membership list. Documents here are added manually via the
    // Firebase Console (doc ID = the admin's Firebase Auth UID).
    // No client can write to this collection.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Premium subscription status, doc ID = vendor's Firebase Auth UID.
    // Only that vendor (or an admin) can read their own status. Writes
    // happen only from the createSubscription/verifySubscription/
    // cancelSubscription Cloud Functions using the Admin SDK, which
    // bypasses these rules — so no client write path is opened here.
    match /premium_vendors/{uid} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }

    // Google Business Profile connection status + response settings,
    // doc ID = vendor's Firebase Auth UID. The vendor can read their own
    // connection, and can update non-token fields (disconnecting,
    // response settings) themselves. The refreshToken/accessToken fields
    // are only ever written by the googleOAuthCallback Cloud Function via
    // the Admin SDK, which bypasses these rules.
    match /gbp_connections/{uid} {
      allow read: if request.auth != null &&
        (request.auth.uid == uid || isAdmin());
      allow update: if request.auth != null && request.auth.uid == uid;
      allow create, delete: if false;
    }

    // Individual review + AI response records. Queried by vendorId, so
    // reads are scoped to documents owned by the requesting vendor.
    // Vendors can edit their own response text/status; creation and
    // deletion happen only from backend jobs via the Admin SDK.
    match /review_responses/{docId} {
      allow read: if request.auth != null &&
        (resource.data.vendorId == request.auth.uid || isAdmin());
      allow update: if request.auth != null &&
        resource.data.vendorId == request.auth.uid;
      allow create, delete: if false;
    }
  }
}
