rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // True if the signed-in user owns the listing at vendors/{listingId}.
    // Used to authorize per-listing Premium/Google-connection access for
    // whichever vendor claimed that specific listing.
    function isListingOwner(listingId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/vendors/$(listingId)).data.ownerId == request.auth.uid;
    }

    // Vendor listings: anyone can read (public search).
    // Any signed-in user can create a listing (it becomes theirs).
    // A listing can be edited/deleted by its owner, by an admin,
    // or claimed by a signed-in user who supplies the correct claimCode
    // on a currently-unclaimed (ownerId == null) listing.
    match /vendors/{vendorId} {
      allow read: if true;

      allow create: if request.auth != null && (
        request.resource.data.ownerId == request.auth.uid ||
        (isAdmin() && request.resource.data.ownerId == null)
      );

      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        isAdmin() ||
        (
          resource.data.ownerId == null &&
          request.resource.data.ownerId == request.auth.uid &&
          request.resource.data.claimCode == resource.data.claimCode
        )
      );

      allow delete: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid || isAdmin());

      // Reviews left by any signed-in user. One review per user per
      // vendor, enforced by using the reviewer's own UID as the doc ID —
      // submitting again just edits their existing review instead of
      // creating a second one.
      match /reviews/{uid} {
        allow read: if true;
        allow create, update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null &&
          (request.auth.uid == uid || isAdmin());
      }
    }

    // Admin membership list. Documents here are added manually via the
    // Firebase Console (doc ID = the admin's Firebase Auth UID).
    // No client can write to this collection.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Premium subscription status, doc ID = the LISTING's ID (vendors/{id}),
    // not a user UID — a listing can be premium whether or not it's
    // currently claimed by a vendor account. Readable by an admin or by
    // whoever currently owns that listing. Writes happen only from the
    // createSubscription/verifySubscription/cancelSubscription Cloud
    // Functions using the Admin SDK, which bypasses these rules — so no
    // client write path is opened here.
    match /premium_vendors/{listingId} {
      allow read: if request.auth != null &&
        (isAdmin() || isListingOwner(listingId));
      allow write: if false;
    }

    // Google Business Profile connection status + response settings,
    // doc ID = the LISTING's ID (vendors/{id}). Readable/updatable by an
    // admin or by whoever currently owns that listing — covers both an
    // admin connecting an unclaimed listing on a business's behalf, and a
    // vendor connecting their own claimed listing. The refreshToken/
    // accessToken fields are only ever written by the oauthCallback Cloud
    // Function via the Admin SDK, which bypasses these rules.
    match /gbp_connections/{listingId} {
      allow read: if request.auth != null &&
        (isAdmin() || isListingOwner(listingId));
      allow update: if request.auth != null &&
        (isAdmin() || isListingOwner(listingId));
      allow create, delete: if false;
    }

    // Individual review + AI response records. Queried by listingId, so
    // reads are scoped to documents belonging to a listing the requester
    // is authorized for. Creation and deletion happen only from backend
    // jobs via the Admin SDK.
    match /review_responses/{docId} {
      allow read: if request.auth != null &&
        (isAdmin() || isListingOwner(resource.data.listingId));
      allow update: if request.auth != null &&
        (isAdmin() || isListingOwner(resource.data.listingId));
      allow create, delete: if false;
    }
  }
}
